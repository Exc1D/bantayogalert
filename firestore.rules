rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getRole() {
      return request.auth.token.role;
    }
    
    function getMunicipality() {
      return request.auth.token.municipality;
    }
    
    function isOwnDoc(uid) {
      return request.auth.uid == uid;
    }
    
    // Users collection
    match /users/{uid} {
      allow read: if isAuthenticated() && (
        isOwnDoc(uid) ||
        getRole() == 'provincial_superadmin' ||
        (getRole() == 'municipal_admin' && getMunicipality() == resource.data.municipality)
      );
      allow write: if isAuthenticated() && (
        isOwnDoc(uid) ||
        getRole() == 'provincial_superadmin'
      );
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.submitterUid == request.auth.uid ||
        getRole() == 'provincial_superadmin' ||
        (getRole() == 'municipal_admin' && resource.data.assignedMunicipality == getMunicipality())
      );
      allow create: if isAuthenticated() && (
        request.resource.data.submitterUid == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        (getRole() == 'municipal_admin' && resource.data.assignedMunicipality == getMunicipality()) ||
        getRole() == 'provincial_superadmin'
      );
      allow delete: if getRole() == 'provincial_superadmin';
      
      // Activity subcollection
      match /activity/{activityId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Function only
      }
    }
    
    // Contacts collection
    match /contacts/{contactId} {
      allow read: if isAuthenticated() && (
        getRole() == 'provincial_superadmin' ||
        (getRole() == 'municipal_admin' && resource.data.municipality == getMunicipality())
      );
      allow write: if isAuthenticated() && (
        getRole() == 'provincial_superadmin' ||
        (getRole() == 'municipal_admin' && resource.data.municipality == getMunicipality())
      );
    }
    
    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        (getRole() == 'municipal_admin' && 
          request.resource.data.scope == 'municipality' &&
          request.resource.data.targetMunicipalities[0] == getMunicipality()) ||
        getRole() == 'provincial_superadmin'
      );
      allow update, delete: if isAuthenticated() && (
        getRole() == 'provincial_superadmin' ||
        resource.data.creatorUid == request.auth.uid
      );
      
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && (
          getRole() == 'provincial_superadmin' ||
          resource.data.userUid == request.auth.uid
        );
        allow write: if false;
      }
    }
    
    // Audit collection
    match /audit/{auditId} {
      allow read: if isAuthenticated() && (
        getRole() == 'provincial_superadmin' ||
        (getRole() == 'municipal_admin' && resource.data.actorMunicipality == getMunicipality())
      );
      allow write: if false;
    }
    
    // Analytics (read only for admins, write only for system)
    match /analytics/{path=**} {
      allow read: if isAuthenticated() && (
        getRole() == 'provincial_superadmin' ||
        (getRole() == 'municipal_admin')
      );
      allow write: if false;
    }
  }
}
