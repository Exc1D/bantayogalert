rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // HELPER FUNCTIONS - Municipality Scoping
    // ============================================================

    // Core municipality access helper - used by all collection rules
    // Explicitly rejects null municipality tokens to prevent edge cases
    function hasMunicipalityAccess(request, targetMunicipality) {
      return (
        request.auth != null &&
        request.auth.token.municipality != null &&
        // provincial_superadmin bypasses all scoping
        (request.auth.token.role == 'provincial_superadmin' ||
          // municipal_admin must match target municipality
          (request.auth.token.role == 'municipal_admin' &&
            request.auth.token.municipality == targetMunicipality))
      )
    }

    // Helper for documents with municipality field
    function canAccessMunicipality(targetMunicipality) {
      return hasMunicipalityAccess(request, targetMunicipality)
    }

    // Check if user is authenticated with valid municipality
    // Rejects null municipality tokens explicitly
    function hasValidMunicipality() {
      return request.auth != null && request.auth.token.municipality != null
    }

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null
    }

    // Check role
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role
    }

    // Role-based helpers (aliases for compatibility)
    function isMunicipalityAdmin() {
      return hasRole('municipal_admin');
    }

    function isProvincialSuperadmin() {
      return hasRole('provincial_superadmin');
    }

    // Legacy alias for backwards compatibility
    function hasValidMunicipalityScope(targetMunicipality) {
      return hasMunicipalityAccess(request, targetMunicipality);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId
        || isProvincialSuperadmin()
        || (isMunicipalityAdmin() && request.auth.token.municipality == resource.data.municipality)
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId
        || isProvincialSuperadmin()
      );
    }

    // Admin Requests collection
    match /adminRequests/{requestId} {
      // Anyone authenticated can create a request (for themselves)
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedRole == 'municipal_admin';

      // Users can read their own requests, provincial superadmin can read all
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.uid || isProvincialSuperadmin());

      // Only provincial_superadmin can update (approve/reject)
      allow update: if isProvincialSuperadmin()
        && resource.data.status == 'pending';

      // No deletions
      allow delete: if false;
    }

    // Reports collection - scaffold, full rules in Phase 2
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && hasValidMunicipalityScope(resource.data.assignedMunicipality);
    }

    // Contacts collection - scaffold
    match /contacts/{contactId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasValidMunicipalityScope(resource.data.municipality);
    }

    // Announcements collection - scaffold
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Audit collection - system only
    match /audit/{auditId} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }
  }
}
