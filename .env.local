# Local development - uses Firebase Emulators
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_DATABASE_URL=http://localhost:8080
VITE_FIREBASE_PROJECT_ID=demo-bantayogalert
VITE_FIREBASE_STORAGE_BUCKET=demo-bantayogalert.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000000000000000

# Point Firebase SDK to use emulators
VITE_USE_EMULATOR=true
