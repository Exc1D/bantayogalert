    "react-helmet-async": "3.0.0",
    "react-leaflet": "4.2.1",
    "react-router-dom": "6.5.0",
    "supercluster": "8.0.1",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
