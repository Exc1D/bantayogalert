rules_version = '2';
service firebase.storage {
  match /buckets/{bucket}/objects {
    // Media uploads: media/{userId}/{reportId}/{uuid}.{ext}
    match /media/{userId}/{reportId}/{filename} {
      allow read: if true; // Public read for media
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.size <= 5 * 1024 * 1024 // 5MB per file
        && request.resource.size <= 10 * 1024 * 1024 // 10MB per report total (enforced by counting in Cloud Function)
        && request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp', 'video/mp4']
        && filename.matches('.*\\.(jpg|jpeg|png|webp|mp4)');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
