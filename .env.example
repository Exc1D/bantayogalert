# Firebase Configuration (D-05: Single Firebase project, environment overlays)
# Copy to .env.local for local development

# Web API Key
VITE_FIREBASE_API_KEY=your_api_key_here

# Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firestore Database URL
VITE_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com

# Project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

# Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# App ID
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Cloud Messaging VAPID Key (Phase 10 - push notifications)
# Generate via: Firebase Console > Project Settings > Cloud Messaging > Web Push Certificates
VITE_FCM_VAPID_KEY=your_vapid_public_key_here

# Measurement ID (optional)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# App Check rollout
VITE_APP_CHECK_MODE=audit
VITE_APP_CHECK_DEBUG_TOKEN=your_debug_token_here

# reCAPTCHA Enterprise Site Key (required when VITE_APP_CHECK_MODE=enforce in production)
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
