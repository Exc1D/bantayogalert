# Firebase Configuration (D-05: Single Firebase project, environment overlays)
# Copy to .env.local for local development

# Web API Key
VITE_FIREBASE_API_KEY=your_api_key_here

# Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firestore Database URL
VITE_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com

# Project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

# Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# App ID
VITE_FIREBASE_APP_ID=your_app_id

# Measurement ID (optional)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# App Check (for Phase 3 - audit mode)
VITE_FIREBASE_APP_CHECK_KEY=your_app_check_key_here

# reCAPTCHA Enterprise Site Key (Phase 12 - enforced mode)
# For Phase 3 audit mode, this is a placeholder
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
